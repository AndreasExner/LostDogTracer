{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": ["/css/*", "/js/*", "/api/*", "/*.json", "/*.png", "/*.ico"]
    },
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": ["anonymous"]
        }
    ],
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html"
        }
    },
    "globalHeaders": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin"
    },
    "platform": {
        "apiRuntime": "dotnet-isolated:8.0"
    }
}
